COMPOSE_PROJECT_NAME=spire

SPIRE_GAME_LISTEN_PORT=6400
SPIRE_ADMIN_LISTEN_PORT=6450

SPIRE_GAME_CERTIFICATE_FILE=/run/secrets/game-cert.pem
SPIRE_GAME_PRIVATE_KEY_FILE=/run/secrets/game-key.pem

SPIRE_LOBBY_PORT=8080
SPIRE_LOBBY_CERTIFICATE_FILE=/run/secrets/lobby-cert.pem
SPIRE_LOBBY_PRIVATE_KEY_FILE=/run/secrets/lobby-key.pem
SPIRE_AUTH_KEY_FILE=/run/secrets/auth-key.txt

SPIRE_DATABASE_HOST=database
SPIRE_DATABASE_PORT=5432
SPIRE_DATABASE_USER=spire
SPIRE_DATABASE_PASSWORD_FILE=/run/secrets/database-password.txt
SPIRE_DATABASE_NAME=spire
